<!--
  Custom Wazuh rules for the AI autoencoder anomaly detector.

  Alerts are injected into the manager's queue socket with location
  "anomaly_detector" and a JSON body under the "anomaly_detector" object.
  Install by appending these rules to /var/ossec/etc/rules/local_rules.xml
  (or referencing this file) and restarting wazuh-manager.
-->
<group name="anomaly_detector,">

  <!-- This rule is level 12, so it triggers e-mail when the manager has
       email_notification enabled and email_alert_level <= 12. Flooding is held
       back by the detector's per-signature throttle and the manager's
       email_maxperhour, so e-mail is intentionally NOT suppressed here. -->
  <rule id="100100" level="12">
    <decoded_as>json</decoded_as>
    <field name="anomaly_detector.agent_id">\.+</field>
    <description>AI Autoencoder: anomalous behaviour on agent $(anomaly_detector.agent_id) user $(anomaly_detector.user) - process $(anomaly_detector.process_name), severity $(anomaly_detector.severity)x (score $(anomaly_detector.anomaly_score)) - why: $(anomaly_detector.explanation) - cmd: $(anomaly_detector.command)</description>
    <group>anomaly_detection,gdpr_IV_35.7.d,pci_dss_10.6.1,</group>
  </rule>

</group>
