<!--
  Custom Wazuh rules for the AI autoencoder anomaly detector.

  Alerts are injected into the manager's queue socket with location
  "anomaly_detector" and a JSON body under the "anomaly_detector" object.
  Install by appending these rules to /var/ossec/etc/rules/local_rules.xml
  (or referencing this file) and restarting wazuh-manager.
-->
<group name="anomaly_detector,">

  <rule id="100100" level="12">
    <decoded_as>json</decoded_as>
    <field name="anomaly_detector.agent_id">\.+</field>
    <!-- Email is suppressed at the rule level: the detector already throttles
         duplicate alerts, but this is a hard backstop against mail floods.
         Remove this line if you want e-mail on every anomaly. -->
    <options>no_email_alert</options>
    <description>AI Autoencoder: anomalous behaviour on agent $(anomaly_detector.agent_id) - process $(anomaly_detector.process_name), score $(anomaly_detector.anomaly_score)</description>
    <group>anomaly_detection,gdpr_IV_35.7.d,pci_dss_10.6.1,</group>
  </rule>

</group>
